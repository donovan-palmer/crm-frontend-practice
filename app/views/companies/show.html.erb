<h1><%= @company["name"] %></h1>
<p class="text-muted"><%= @company["city"] %>, <%= @company["state"] %></p>

<div class="row mt-4">
  <!-- Left column: Contacts -->
  <div class="col-md-6">
    <h3>Contacts</h3>

    <ul class="list-unstyled">
      <% for contact in @contacts %>
        <li class="d-flex align-items-center mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person-square me-3 text-secondary flex-shrink-0" viewBox="0 0 16 16">
            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
            <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1v-1c0-1-1-4-6-4s-6 3-6 4v1a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
          </svg>
          <div>
            <a href="/contacts/<%= contact["id"] %>">
              <%= contact["first_name"] %> <%= contact["last_name"] %>
            </a>
          </div>
        </li>
      <% end %>
    </ul>

    <p>
      <a href="/contacts/new?company_id=<%= @company["id"] %>" class="btn btn-outline-dark btn-sm">New Contact</a>
    </p>

    <p><a href="/companies" class="btn btn-link px-0">Back to All Companies</a></p>

    <% if User.find_by({ "id" => session["user_id"] }) != nil %>
      <p>
        <a href="/companies/<%= @company["id"] %>/edit" class="btn btn-outline-secondary btn-sm">Edit Company</a>
      </p>

      <form action="/companies/<%= @company["id"] %>" method="post">
        <input type="hidden" name="_method" value="delete">
        <button class="btn btn-outline-danger btn-sm">Delete Company</button>
      </form>
    <% end %>
  </div>

  <!-- Right column: Sales Activity -->
  <div class="col-md-6">
    <h3>Sales Activity</h3>

    <% for activity in @activities %>
      <% activity_contact = Contact.find_by({ "id" => activity["contact_id"] }) %>
      <% activity_user = User.find_by({ "id" => activity["user_id"] }) %>
      <div class="mb-4">
        <p class="mb-1">
          <strong>
            <%= activity["activity_type"].capitalize %> between
            <a href="/contacts/<%= activity_contact["id"] %>"><%= activity_contact["first_name"] %> <%= activity_contact["last_name"] %></a>
            and <%= activity_user["first_name"] %>
            on <%= activity["created_at"].strftime("%A, %B %-d") %>:
          </strong>
        </p>
        <p class="fst-italic mb-0"><%= activity["note"] %></p>
      </div>
    <% end %>

    <% if User.find_by({ "id" => session["user_id"] }) != nil %>
      <h3 class="mt-4">Log a new sales activity</h3>

      <form action="/activities" method="post">
        <div class="mb-3 d-flex align-items-center gap-2">
          <label for="contact_id_select" class="form-label mb-0">With</label>
          <select name="contact_id" id="contact_id_select" class="form-select w-auto">
            <% for contact in @contacts %>
              <option value="<%= contact["id"] %>"><%= contact["first_name"] %> <%= contact["last_name"] %></option>
            <% end %>
          </select>
        </div>

        <div class="mb-3">
          <textarea name="note" class="form-control" rows="4"></textarea>
        </div>

        <input type="hidden" name="activity_type" value="call">

        <button class="btn btn-dark">Submit</button>
      </form>
    <% end %>
  </div>
</div>
